# ─── Docker Compose root .env ─────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores

# Base de datos
DB_USER=tohan_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=taller_tohan

# JWT (genera con: node -e "require('crypto').randomBytes(64).toString('hex')")
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
COOKIE_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX_DIFFERENT

# URLs
FRONTEND_URL=https://tallertohan.com
